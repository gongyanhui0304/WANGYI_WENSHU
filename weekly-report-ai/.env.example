# ==============================================================
# 信息中心周报智能生成系统 - 环境变量配置
# 复制此文件为 .env 并填写真实配置
# ==============================================================

# 应用配置
APP_NAME=信息中心周报智能生成系统
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string

# SQLite 本地数据库路径
DATABASE_URL=sqlite:///data/sqlite/weekly_report.db

# ==============================================================
# SmartBI 数据库 (SQL Server)
# ==============================================================
SMARTBI_SQLSERVER_HOST=your-sqlserver-host
SMARTBI_SQLSERVER_PORT=1433
SMARTBI_SQLSERVER_DATABASE=SmartBI
SMARTBI_SQLSERVER_USER=your-username
SMARTBI_SQLSERVER_PASSWORD=your-password
SMARTBI_SQLSERVER_DRIVER="ODBC Driver 18 for SQL Server"

# ==============================================================
# Redmine 数据库 (PostgreSQL)
# ==============================================================
REDMINE_POSTGRES_HOST=your-postgres-host
REDMINE_POSTGRES_PORT=5432
REDMINE_POSTGRES_DATABASE=redmine
REDMINE_POSTGRES_USER=your-username
REDMINE_POSTGRES_PASSWORD=your-password

# ==============================================================
# DeepSeek AI API 配置 (OpenAI-compatible)
# ==============================================================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ==============================================================
# 周报配置
# ==============================================================
WEEKLY_REPORT_MAX_PDF_SIZE_MB=20
WEEKLY_REPORT_OUTPUT_DIR=data/exports
WEEKLY_REPORT_UPLOAD_DIR=data/uploads
