{
    "page":  3,
    "name":  "指标总览",
    "enabled":  true,
    "type":  "metrics",
    "data_source":  [
                        "metrics/metric_registry.json",
                        "data/metrics/\u003crun_id\u003e/registry.json"
                    ],
    "dynamic_fields":  [
                           "metric_id",
                           "metric_name",
                           "metric_value",
                           "source",
                           "ppt_refs"
                       ],
    "fixed_fields":  [
                         "layout",
                         "title",
                         "font",
                         "color",
                         "footer"
                     ],
    "standard_ref":  "ppt/spec/page_standard.md",
    "sql_path":  "无直接业务 SQL；读取已注册 Metric 产物。",
    "metrics":  [
                    "M301",
                    "M302",
                    "M303",
                    "M304"
                ],
    "debug_output_dir":  "output/debug/page_03_metrics",
    "debug_outputs":  [
                          "metrics.json",
                          "ai_summary.md",
                          "metric_registry_snapshot.json",
                          "metric_status.csv",
                          "execution.log"
                      ],
    "drill_down":  {
                       "enabled":  true,
                       "rule":  "指标清单必须支持 PPT -\u003e Metric Registry -\u003e metric.json -\u003e result.csv/result.json -\u003e 来源 SQL 或来源说明。"
                   },
    "visual_reference":  "example.png",
    "trace_required":  true,
    "metric_queries":  {
                           "M301":  {
                                        "source":  "metric_registry",
                                        "metric_name":  "已注册指标数",
                                        "table":  "metrics/metric_registry.json",
                                        "description":  "统计 Metric Registry 中已注册指标数量"
                                    },
                           "M302":  {
                                        "source":  "metric_registry",
                                        "metric_name":  "已生成CSV指标数",
                                        "table":  "data/metrics/\u003crun_id\u003e",
                                        "description":  "统计已生成 result.csv 的指标数量"
                                    },
                           "M303":  {
                                        "source":  "metric_registry",
                                        "metric_name":  "已生成JSON指标数",
                                        "table":  "data/metrics/\u003crun_id\u003e",
                                        "description":  "统计已生成 result.json 的指标数量"
                                    },
                           "M304":  {
                                        "source":  "metric_registry",
                                        "metric_name":  "待接入指标数",
                                        "table":  "metrics/metric_registry.json",
                                        "description":  "统计尚未完成追溯产物的指标数量"
                                    }
                       }
}
