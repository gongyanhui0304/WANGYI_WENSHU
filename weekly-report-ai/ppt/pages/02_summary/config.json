{
    "page":  2,
    "name":  "总览",
    "title":  "总览",
    "enabled":  true,
    "type":  "summary",
    "data_source":  [
                        "Redmine PostgreSQL",
                        "MetricRegistry",
                        "ManualInput"
                    ],
    "dynamic_fields":  [
                           "core_metrics",
                           "weekly_conclusion",
                           "risk_summary",
                           "next_focus"
                       ],
    "fixed_fields":  [
                         "layout",
                         "title",
                         "font",
                         "color",
                         "footer"
                     ],
    "standard_ref":  "ppt/spec/page_standard.md",
    "sql_path":  "knowledge/redmine/sql/",
    "metrics":  [
                    "M201",
                    "M202",
                    "M203",
                    "M204"
                ],
    "debug_output_dir":  "output/debug/page_02_summary",
    "debug_outputs":  [
                          "metrics.json",
                          "ai_summary.md",
                          "redmine_summary.sql",
                          "redmine_summary.csv",
                          "redmine_summary.json",
                          "execution.log"
                      ],
    "drill_down":  {
                       "enabled":  true,
                       "rule":  "总览 KPI 和趋势结论必须支持 PPT -\u003e Metric -\u003e SQL -\u003e CSV/JSON -\u003e Issue 明细 -\u003e Redmine 原始记录。"
                   },
    "visual_reference":  "example.png",
    "trace_required":  true,
    "metric_queries":  {
                           "M201":  {
                                        "source":  "redmine_postgres",
                                        "sql_file":  "knowledge/redmine/sql/metrics/M201_total_issues.sql",
                                        "value_mode":  "row_count",
                                        "table":  "issues",
                                        "description":  "统计 Redmine 全部需求明细，指标值为明细行数"
                                    },
                           "M202":  {
                                        "source":  "redmine_postgres",
                                        "sql_file":  "knowledge/redmine/sql/metrics/M202_new_issues_this_week.sql",
                                        "value_mode":  "row_count",
                                        "table":  "issues",
                                        "description":  "统计 created_on 落在本周周期内的需求明细"
                                    },
                           "M203":  {
                                        "source":  "redmine_postgres",
                                        "sql_file":  "knowledge/redmine/sql/metrics/M203_closed_issues_this_week.sql",
                                        "value_mode":  "row_count",
                                        "table":  "issues",
                                        "description":  "统计 closed_on 落在本周周期内的需求明细"
                                    },
                           "M204":  {
                                        "source":  "redmine_postgres",
                                        "sql_file":  "knowledge/redmine/sql/metrics/M204_risk_overdue_issues.sql",
                                        "value_mode":  "row_count",
                                        "table":  "issues",
                                        "description":  "统计到期未关闭需求作为总览风险提示来源"
                                    }
                       }
}
