{
    "version":  "1.0",
    "rule":  "禁止 PPT 出现无法追溯的数据；所有 AI 分析和 PPT 数字必须引用 Metric ID。",
    "artifact_root":  "data/metrics/\u003crun_id\u003e/",
    "required_files":  [
                           "metric.json",
                           "query.sql",
                           "result.csv",
                           "result.json",
                           "summary.md"
                       ],
    "metrics":  [
                    {
                        "metric_id":  "M001",
                        "metric_name":  "总需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues",
                        "description":  "统计 Redmine issues 全部需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M002",
                        "metric_name":  "本周新增需求",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues",
                        "description":  "统计 created_on 落在本周周期内的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M003",
                        "metric_name":  "本周完成需求",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues",
                        "description":  "统计 closed_on 落在本周周期内的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M004",
                        "metric_name":  "AI应用需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/projects/custom_fields",
                        "description":  "统计归属 AI 应用相关系统或项目的需求明细，具体 SQL 按项目映射维护"
                    },
                    {
                        "metric_id":  "M005",
                        "metric_name":  "BI需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/projects/custom_fields",
                        "description":  "统计归属 BI 相关系统或项目的需求明细，具体 SQL 按项目映射维护"
                    },
                    {
                        "metric_id":  "M006",
                        "metric_name":  "进行中需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/issue_statuses",
                        "description":  "统计状态为新建或进行中的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M007",
                        "metric_name":  "已完成需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/issue_statuses",
                        "description":  "统计状态为已关闭、已解决、已拒绝的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M008",
                        "metric_name":  "延期需求数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/issue_statuses/projects",
                        "description":  "统计 due_date 已过且未处于完成状态的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M009",
                        "metric_name":  "项目总数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "projects",
                        "description":  "统计 Redmine 项目明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M010",
                        "metric_name":  "本周活跃项目数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/projects",
                        "description":  "统计本周有需求更新的去重项目明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M011",
                        "metric_name":  "Redmine活跃用户数",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/users",
                        "description":  "统计存在需求分派记录的去重负责人明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M012",
                        "metric_name":  "项目进展明细",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/projects/issue_statuses",
                        "description":  "按项目统计完成、待处理、本周活跃和本周新增需求，用于项目表格"
                    },
                    {
                        "metric_id":  "M013",
                        "metric_name":  "延期需求明细",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues/projects/issue_statuses",
                        "description":  "输出延期需求明细，包含 Issue 编号、主题、项目、状态、到期日和延期天数"
                    },
                    {
                        "metric_id":  "M014",
                        "metric_name":  "本周更新需求",
                        "source":  "Redmine PostgreSQL",
                        "table":  "issues",
                        "description":  "统计 updated_on 落在本周周期内的需求明细，指标值为明细行数"
                    },
                    {
                        "metric_id":  "M401",
                        "metric_name":  "报表总数",
                        "source":  "SmartBI SQL Server",
                        "table":  "SmartBI report/access log tables",
                        "description":  "统计第4页低活跃治理范围内的 SmartBI 报表总数，优先复用 knowledge/smartbi/sql 既有 SQL"
                    },
                    {
                        "metric_id":  "M402",
                        "metric_name":  "低活跃报表数量",
                        "source":  "SmartBI SQL Server",
                        "table":  "SmartBI report/access log tables",
                        "description":  "统计满足低活跃规则的报表数量：近30天访问次数 \u003c= 5 或近7天访问次数 = 0；若 SQL 已定义则优先采用 SQL 口径"
                    },
                    {
                        "metric_id":  "M403",
                        "metric_name":  "近7天零访问数量",
                        "source":  "SmartBI SQL Server",
                        "table":  "SmartBI access log tables",
                        "description":  "统计近7天访问次数为 0 的报表数量，需可穿透到报表明细和访问日志"
                    },
                    {
                        "metric_id":  "M404",
                        "metric_name":  "低活跃占比",
                        "source":  "SmartBI SQL Server",
                        "table":  "derived metric",
                        "description":  "低活跃报表数量 / 报表总数，分子引用 M402，分母引用 M401"
                    },
                    {
                        "metric_id":  "M405",
                        "metric_name":  "系统低活跃统计",
                        "source":  "SmartBI SQL Server",
                        "table":  "SmartBI report/access log tables",
                        "description":  "按 SAP、BI、PLM、MOM、OA、AI应用、其它统计低活跃报表数量，用于横向柱状图"
                    },
                    {
                        "metric_id":  "M406",
                        "metric_name":  "低活跃Top20",
                        "source":  "SmartBI SQL Server",
                        "table":  "SmartBI report/access log tables",
                        "description":  "低活跃报表 Top20 明细，按访问次数升序，字段包含系统、报表编码、报表名称、近7天访问、近30天访问、最近访问时间和治理建议"
                    },
                    {
                        "metric_id":  "M901",
                        "metric_name":  "已上线项目数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本固定值，需迁移为项目状态 SQL 指标"
                    },
                    {
                        "metric_id":  "M902",
                        "metric_name":  "正常项目数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本固定值，需迁移为项目状态 SQL 指标"
                    },
                    {
                        "metric_id":  "M904",
                        "metric_name":  "SAP模块月访问基数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本用于估算 SAP 模块月访问的固定基数，需迁移为 SQL-backed metric"
                    },
                    {
                        "metric_id":  "M905",
                        "metric_name":  "OA权限账号数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本固定值，需迁移为 OA 权限账号 SQL 指标"
                    },
                    {
                        "metric_id":  "M906",
                        "metric_name":  "OA周活跃数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本估算值，需迁移为 OA 周活跃 SQL 指标"
                    },
                    {
                        "metric_id":  "M907",
                        "metric_name":  "PLM总账号数",
                        "source":  "Legacy script constant",
                        "table":  "manual",
                        "description":  "历史脚本固定值，需迁移为 PLM 账号 SQL 指标"
                    },
                    {
                        "table":  "system_date",
                        "source":  "SystemDate",
                        "description":  "根据系统当前日期计算自然周，用于第1页封面。",
                        "metric_id":  "M101",
                        "metric_name":  "周数"
                    },
                    {
                        "table":  "system_date",
                        "source":  "SystemDate",
                        "description":  "根据系统当前日期计算周一至周日日期范围，用于第1页封面。",
                        "metric_id":  "M102",
                        "metric_name":  "日期范围"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第2页总览使用的需求总数，需追溯到 Redmine Issue 明细。",
                        "metric_id":  "M201",
                        "metric_name":  "总览总需求数"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第2页总览使用的本周新增需求，按 created_on 统计。",
                        "metric_id":  "M202",
                        "metric_name":  "总览本周新增需求"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第2页总览使用的本周完成需求，按 closed_on 或完成状态统计。",
                        "metric_id":  "M203",
                        "metric_name":  "总览本周完成需求"
                    },
                    {
                        "table":  "issues/manual",
                        "source":  "Redmine PostgreSQL/ManualInput",
                        "description":  "第2页总览使用的风险提示数量，来源于风险明细或人工补充。",
                        "metric_id":  "M204",
                        "metric_name":  "总览风险提示数"
                    },
                    {
                        "table":  "metrics/metric_registry.json",
                        "source":  "MetricRegistry",
                        "description":  "第3页统计 Metric Registry 中已注册指标数量。",
                        "metric_id":  "M301",
                        "metric_name":  "已注册指标数"
                    },
                    {
                        "table":  "data/metrics/\u003crun_id\u003e",
                        "source":  "MetricRegistry",
                        "description":  "第3页统计已生成 result.csv 的指标数量。",
                        "metric_id":  "M302",
                        "metric_name":  "已生成CSV指标数"
                    },
                    {
                        "table":  "data/metrics/\u003crun_id\u003e",
                        "source":  "MetricRegistry",
                        "description":  "第3页统计已生成 result.json 的指标数量。",
                        "metric_id":  "M303",
                        "metric_name":  "已生成JSON指标数"
                    },
                    {
                        "table":  "metrics/metric_registry.json",
                        "source":  "MetricRegistry",
                        "description":  "第3页统计尚未完成 SQL/CSV/JSON 追溯产物的指标数量。",
                        "metric_id":  "M304",
                        "metric_name":  "待接入指标数"
                    },
                    {
                        "table":  "system access logs",
                        "source":  "SmartBI SQLServer/API",
                        "description":  "第5页按系统统计活跃用户数量。",
                        "metric_id":  "M501",
                        "metric_name":  "系统活跃用户数"
                    },
                    {
                        "table":  "system access logs",
                        "source":  "SmartBI SQLServer/API",
                        "description":  "第5页按系统统计访问次数。",
                        "metric_id":  "M502",
                        "metric_name":  "系统访问次数"
                    },
                    {
                        "table":  "derived metric",
                        "source":  "SmartBI SQLServer/API",
                        "description":  "第5页统计系统活跃度较上期变化。",
                        "metric_id":  "M503",
                        "metric_name":  "系统环比变化"
                    },
                    {
                        "table":  "system access logs",
                        "source":  "SmartBI SQLServer/API",
                        "description":  "第5页统计低活跃或异常波动系统数量。",
                        "metric_id":  "M504",
                        "metric_name":  "异常系统数"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页需求流转使用的总需求数。",
                        "metric_id":  "M601",
                        "metric_name":  "需求流转总需求数"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页按 created_on 统计本周新增需求。",
                        "metric_id":  "M602",
                        "metric_name":  "需求流转本周新增需求"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页按 closed_on 或完成状态统计本周完成需求。",
                        "metric_id":  "M603",
                        "metric_name":  "需求流转本周完成需求"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页按 updated_on 统计本周更新需求。",
                        "metric_id":  "M604",
                        "metric_name":  "本周更新需求"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页统计到期未完成需求数量。",
                        "metric_id":  "M605",
                        "metric_name":  "延期需求数"
                    },
                    {
                        "table":  "derived metric",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第6页由完成需求数和总需求/新增需求等口径计算完成率。",
                        "metric_id":  "M606",
                        "metric_name":  "需求完成率"
                    },
                    {
                        "table":  "projects",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第7页项目看板统计项目总数。",
                        "metric_id":  "M701",
                        "metric_name":  "项目总数"
                    },
                    {
                        "table":  "issues/projects",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第7页统计本周有需求更新或进展的项目数量。",
                        "metric_id":  "M702",
                        "metric_name":  "本周活跃项目数"
                    },
                    {
                        "table":  "projects/issues/manual",
                        "source":  "Redmine PostgreSQL/ManualInput",
                        "description":  "第7页重点项目进展明细，SQL 数据和人工补充均需标注来源。",
                        "metric_id":  "M703",
                        "metric_name":  "重点项目进展"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第7页按项目统计待处理需求数量。",
                        "metric_id":  "M704",
                        "metric_name":  "待处理需求数"
                    },
                    {
                        "table":  "projects/issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第7页统计存在延期需求的项目数量。",
                        "metric_id":  "M705",
                        "metric_name":  "延期项目数"
                    },
                    {
                        "table":  "issues/reports/manual",
                        "source":  "Redmine PostgreSQL/SmartBI SQLServer/ManualInput",
                        "description":  "第8页统计风险项总数。",
                        "metric_id":  "M801",
                        "metric_name":  "风险项数量"
                    },
                    {
                        "table":  "issues",
                        "source":  "Redmine PostgreSQL",
                        "description":  "第8页统计由延期需求形成的风险数量。",
                        "metric_id":  "M802",
                        "metric_name":  "延期风险数量"
                    },
                    {
                        "table":  "SmartBI report/access log tables",
                        "source":  "SmartBI SQLServer",
                        "description":  "第8页统计由低活跃报表治理形成的风险数量。",
                        "metric_id":  "M803",
                        "metric_name":  "低活跃治理风险数量"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第8页统计数据缺口或待确认事项数量。",
                        "metric_id":  "M804",
                        "metric_name":  "数据缺口数量"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第9页统计下周重点事项数量。",
                        "metric_id":  "M908",
                        "metric_name":  "下周重点事项数"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第9页统计项目推进类计划数量。",
                        "metric_id":  "M909",
                        "metric_name":  "项目推进计划数"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第9页统计系统治理类计划数量。",
                        "metric_id":  "M910",
                        "metric_name":  "系统治理计划数"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第9页统计需协调事项数量。",
                        "metric_id":  "M911",
                        "metric_name":  "需协调事项数"
                    },
                    {
                        "table":  "metrics/metric_registry.json",
                        "source":  "MetricRegistry",
                        "description":  "第10页附录统计指标口径数量。",
                        "metric_id":  "M1001",
                        "metric_name":  "指标口径数量"
                    },
                    {
                        "table":  "metrics/metric_registry.json",
                        "source":  "MetricRegistry",
                        "description":  "第10页附录统计数据源数量。",
                        "metric_id":  "M1002",
                        "metric_name":  "数据源数量"
                    },
                    {
                        "table":  "data/metrics/\u003crun_id\u003e",
                        "source":  "MetricRegistry",
                        "description":  "第10页附录统计可用追溯路径数量。",
                        "metric_id":  "M1003",
                        "metric_name":  "追溯路径数量"
                    },
                    {
                        "table":  "manual/metrics",
                        "source":  "ManualInput/MetricRegistry",
                        "description":  "第10页附录统计待确认事项数量。",
                        "metric_id":  "M1004",
                        "metric_name":  "待确认事项数量"
                    }
                ]
}
