# Business web app config.
# This file belongs on the server or in a protected EnvironmentFile.

BUSINESS_APP_HOST=0.0.0.0
BUSINESS_APP_PORT=8780

# Usually this is the local MCP API on the same server.
MAIL_MCP_BASE_URL=http://127.0.0.1:8765

# Protected server-side map from enterprise user id to MCP token.
# The browser must never receive the MCP token.
BUSINESS_USER_TOKEN_FILE=/path/to/protected/business_user_tokens.json

# Production: a trusted gateway/SSO proxy injects this header after login.
BUSINESS_AUTH_MODE=trusted_header
BUSINESS_AUTH_HEADER=X-Authenticated-User

# Local demo only:
# BUSINESS_AUTH_MODE=demo_cookie
# Open /login?user_id=user_a once, then use /
BUSINESS_SESSION_COOKIE_NAME=mail_user
