# Development/test helper only.
# Business users should not edit or receive this file.
#
# Copy this file to:
# config/server_connection.local.env
#
# Fill values locally only for developers/admins/technical Codex users. Do not send real tokens, passwords,
# private keys, or account credentials in chat, docs, or commits.

MAIL_MCP_BASE_URL=http://<mcp-server-host>:<port>
MAIL_MCP_TOKEN=<user-specific-token>

# Optional audit/reference values. Codex Skill must not SSH or scan raw mail directly.
BASTION_URL=<optional-bastion-url>
BASTION_ASSET=<optional-bastion-asset-name>
SERVER_RAW_MAIL_ROOT=<server-raw-mail-root>
SERVER_CODEX_INDEX_ROOT=<server-index-root>
SERVER_CODEX_LOGS_ROOT=<server-logs-root>


