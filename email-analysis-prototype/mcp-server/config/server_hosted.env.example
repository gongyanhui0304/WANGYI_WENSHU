# Server-side environment for the central mail analysis service.
# Copy to a protected server path, for example /etc/email-analysis/email-analysis.env.

MAIL_API_HOST=0.0.0.0
MAIL_API_PORT=8765

MAIL_RAW_ROOT=/path/to/raw-mails
MAIL_INDEX_ROOT=/path/to/mail-index
MAIL_LOG_ROOT=/path/to/mail-logs
MAIL_PERMISSIONS_FILE=/path/to/mail-index/permissions.json

# The same service exposes:
# - remote MCP: POST http://<host>:8765/mcp
# - legacy HTTP endpoints for the optional stdio bridge.

# Optional comma-separated project/customer/industry keywords for indexing.
MAIL_INDEX_EXTRA_KEYWORDS=

# Where deploy_server_bootstrap.sh installs runtime files.
SERVER_APP_ROOT=/opt/email-analysis/mcp_email_server

# Optional business access layer. This is not the recommended agent entry.
BUSINESS_APP_HOST=0.0.0.0
BUSINESS_APP_PORT=8780
BUSINESS_USER_TOKEN_FILE=/path/to/protected/business_user_tokens.json
BUSINESS_AUTH_MODE=trusted_header
BUSINESS_AUTH_HEADER=X-Authenticated-User
