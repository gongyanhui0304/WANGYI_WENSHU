[Unit]
Description=Email Analysis MCP HTTP API
After=network.target

[Service]
Type=simple
WorkingDirectory=<server-project-root>/runtime/mcp_email_server
EnvironmentFile=<server-env-file>
ExecStart=/usr/bin/python3 mail_http_api.py
Restart=always
RestartSec=5
User=<service-user>
Group=<service-group>

[Install]
WantedBy=multi-user.target
